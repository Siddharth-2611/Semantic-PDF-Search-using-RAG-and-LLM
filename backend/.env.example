# --- Database ---
# For local dev without Postgres installed, you can use SQLite instead:
# DATABASE_URL=sqlite:///./app.db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pdf_search

# --- Auth ---
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- LLM (OpenRouter, OpenAI-compatible) ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash

# --- Embeddings ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Storage ---
UPLOAD_DIR=./storage/uploads
FAISS_INDEX_DIR=./storage/faiss_index

# --- Chunking ---
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# --- Email (SMTP via Gmail App Password) ---
# 1. Enable 2-Step Verification on your Google account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use that 16-character app password below (NOT your regular Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=[email protected]
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_EMAIL=[email protected]
VERIFICATION_CODE_EXPIRE_MINUTES=10
